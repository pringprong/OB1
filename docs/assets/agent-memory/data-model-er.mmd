  thoughts {
    uuid id PK
    text content
    vector embedding
  }

  agent_memories {
    uuid id PK
    uuid thought_id FK
    uuid workspace_id
    uuid project_id
    text memory_type
    text provenance_status
    text review_status
    boolean can_use_as_instruction
    boolean can_use_as_evidence
  }

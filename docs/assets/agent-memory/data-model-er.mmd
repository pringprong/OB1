  agent_memories ||--o{ agent_memory_source_refs : " cites"
  agent_memories ||--o{ agent_memory_artifacts : "links"
  agent_memories ||--o{ agent_memory_relations : "relates"
  agent_memories ||--o{ agent_memory_review_actions : "reviewed by"
  agent_memory_recall_traces ||--o{ agent_memory_recall_items : "returns"
  agent_memories ||--o{ agent_memory_recall_items : "included in"
  agent_memories ||--o{ agent_memory_audit_events : "audited"
